{
  "name": "sir-system-monitor",
  "version": "1.1.0",
  "description": "Electron app for monitoring system statistics",
  "repository": {
    "type": "git",
    "url": "https://github.com/KaMiKaZeE1221/SiR-System-Monitor"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "40.7.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "koffi": "^2.15.1",
    "systeminformation": "^5.21.0"
  },
  "build": {
    "appId": "com.sir.systemmonitor",
    "productName": "SiR System Monitor",
    "files": [
      "**/*",
      "!dist/**",
      "!dist*/**",
      "!build/**",
      "!recovered_source_from_setup_1_0_6/**",
      "!restored_from_setup_1_0_6/**",
      "!docs/**",
      "!.git/**",
      "!.vscode/**",
      "!GITHUB_UPLOAD_GUIDE.md",
      "!$null",
      "!_sensor_dump*.txt",
      "!*.log",
      "!README.md",
      "!test-*.js"
    ],
    "directories": {
      "output": "dist"
    },
    "icon": "SiR_SM.ico",
    "win": {
      "icon": "SiR_SM.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "portable": {
      "artifactName": "SiR-System-Monitor-Portable-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "KaMiKaZeE1221",
        "repo": "SiR-System-Monitor"
      }
    ],
    "nsis": {
      "artifactName": "SiR-System-Monitor-Setup-${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SiR System Monitor"
    }
  }
}
